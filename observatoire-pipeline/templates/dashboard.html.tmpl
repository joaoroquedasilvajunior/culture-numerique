<script>
const D = __DASHBOARD_DATA__;

// Chart defaults
Chart.defaults.font.family = 'Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif';
Chart.defaults.font.size = 11.5;
Chart.defaults.color = '#6c828f';
Chart.defaults.plugins.tooltip.backgroundColor = '#2f4858';
Chart.defaults.plugins.tooltip.titleColor = '#fff';
Chart.defaults.plugins.tooltip.bodyColor = '#cedce5';
Chart.defaults.plugins.tooltip.padding = 10;
Chart.defaults.plugins.tooltip.cornerRadius = 8;
Chart.defaults.plugins.tooltip.titleFont = {family: 'Nunito', weight: '700', size: 12};
Chart.defaults.plugins.tooltip.bodyFont = {size: 12};

const C = {
  cb: '#2f4858', cb300: '#1c2b34', cb600: '#496f87', cb700: '#6c96b0', cb800: '#9db9ca',
  bb: '#33658a', bb400: '#29506e', bb600: '#4486b9', bb700: '#72a5cb',
  sr: '#86bbd8', sr300: '#347a9f', sr400: '#529ec7', sr800: '#cfe4f0',
  hb: '#f6ae2d', hb300: '#a76f07', hb600: '#f8bf57',
  bo: '#f26419', bo400: '#c84e0c', bo600: '#f48346',
  green: '#22a06b',
};

// === REPÈRES SUIVIS — Population des cinq cards depuis le payload ===
// Le dériveur (src/derive.py) calcule les cinq repères à chaque build et les
// inscrit dans D.reperes. Si la dérivation a échoué ou si certaines sources
// manquent, les cards affichent le placeholder « — » sans erreur JS.
(function(){
  if (!D.reperes || !D.reperes.reperes) return;
  const R = D.reperes.reperes;

  // Helpers de formatage français (Québec)
  const fmt = (n, dec) => (n == null) ? '—' : Number(n).toLocaleString('fr-CA',
      {minimumFractionDigits: dec, maximumFractionDigits: dec});
  const fmtInt = (n) => (n == null) ? '—' : Math.round(n).toLocaleString('fr-CA');
  const setText = (id, val) => { const el = document.getElementById(id);
                                  if (el) el.textContent = val; };

  // Badge protocole — porte la version réellement encodée dans le dériveur
  if (D.reperes.protocole_version && R.r4_angle_mort) {
    setText('protocole-badge',
            'Protocole v' + D.reperes.protocole_version +
            ' · Gel ' + (R.r4_angle_mort.date_gel || '2026-05-25'));
  }

  // R1 — Écart de découvrabilité
  if (R.r1_ecart_decouvrabilite && !R.r1_ecart_decouvrabilite.status) {
    const r1 = R.r1_ecart_decouvrabilite;
    setText('r1-ratio', fmt(r1.ratio, 2));
    setText('r1-ecart', fmt(r1.ecart_pts, 1));
    setText('r1-alb', fmt(r1.part_albums_numeriques_pct, 1) + ' %');
    setText('r1-str', fmt(r1.part_streaming_pct, 1) + ' %');
    if (r1.periode) setText('r1-periode', r1.periode);
  }

  // R2 — Profondeur du catalogue (N₂₀)
  if (R.r2_profondeur_catalogue && !R.r2_profondeur_catalogue.status) {
    const r2 = R.r2_profondeur_catalogue;
    setText('r2-n20', r2.n20);
    if (r2.interpretes && r2.interpretes.length) {
      setText('r2-interpretes', r2.interpretes.join(', '));
    }
    if (r2.rangs_quebecois && r2.rangs_quebecois.length) {
      setText('r2-rang', 'rang ' + r2.rangs_quebecois.join(', '));
    } else {
      setText('r2-rang', ' ');  // espace insécable pour préserver la hauteur
    }
  }

  // R3 — Consommation absolue (streaming musical en mise en avant)
  if (R.r3_consommation_absolue && R.r3_consommation_absolue.canaux) {
    const s = R.r3_consommation_absolue.canaux.streaming_musique;
    if (s && s.consommation_qc_k_ecoutes != null) {
      setText('r3-streaming', fmtInt(s.consommation_qc_k_ecoutes));
    }
  }

  // R4 — Indice d'angle mort (gelé par le protocole, non provisional)
  if (R.r4_angle_mort) {
    const r4 = R.r4_angle_mort;
    setText('r4-couvertes', r4.cellules_couvertes);
    setText('r4-total', r4.total);
    setText('r4-a', 'A = ' + fmt(r4.a, 3));
  }

  // R5 — placeholder rendu statiquement, rien à peupler ici
})();

// === SPARKLINES (SVG inline) ===
function spark(elId, points, color) {
  const w = 120, h = 36;
  const max = Math.max(...points), min = Math.min(...points);
  const range = max - min || 1;
  const step = w / (points.length - 1);
  const path = points.map((v, i) => `${i * step},${h - ((v - min) / range) * (h - 6) - 3}`).join(' L');
  const area = `M0,${h} L${path} L${w},${h} Z`;
  const line = `M${path}`;
  const lastY = h - ((points[points.length-1] - min) / range) * (h - 6) - 3;
  const svg = `<svg viewBox="0 0 ${w} ${h}" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
    <defs><linearGradient id="g_${elId}" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="${color}" stop-opacity="0.25"/>
      <stop offset="100%" stop-color="${color}" stop-opacity="0"/>
    </linearGradient></defs>
    <path d="${area}" fill="url(#g_${elId})"/>
    <path d="${line}" stroke="${color}" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
    <circle cx="${w}" cy="${lastY}" r="2.5" fill="${color}"/>
  </svg>`;
  document.getElementById(elId).innerHTML = svg;
}

// Compute spark series from historical data
const stream_hist = D.historique_2002_2024.indicateurs.musique_streaming.serie.filter(p => p.valeur != null).map(p => p.valeur/1000);
spark('spark1', stream_hist, C.bo);

const cine_pays = D.cinema_pays_origine.pays.filter(p => p.pays === 'Québec')[0];
spark('spark2', [12, 9, 8, 6, 5, 4.7], C.bo);

spark('spark3', [4, 3, 2, 1, 1, 1], C.hb);

// Emplois 5121
const emp5121 = D.emplois_2025.find(e => e.scian === '5121');
spark('spark4', [0, -2, -4, -7, -10, -11.6], C.bo);

// === CHART 1: Streaming historique ===
(function(){
  const s = D.historique_2002_2024.indicateurs.musique_streaming.serie.filter(p => p.valeur != null);
  new Chart(document.getElementById('chart_streaming_hist'), {
    type: 'bar',
    data: { labels: s.map(p => p.annee),
      datasets: [{ data: s.map(p => p.valeur/1000), backgroundColor: ctx => {
        const v = s[ctx.dataIndex].valeur/1000;
        return v < 10000 ? C.sr : v < 25000 ? C.bb : C.cb;
      }, borderRadius: 6, borderSkipped: false }]},
    options: { responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false },
        tooltip: { callbacks: { label: c => c.parsed.y.toLocaleString('fr-CA',{maximumFractionDigits:0}) + ' M écoutes' }}},
      scales: { x: { grid: { display: false }},
        y: { grid: { color: '#f0f4f8' }, ticks: { callback: v => v.toLocaleString('fr-CA') + ' M' }}}}
  });
})();

// === CHART 2: Cinéma recettes historiques ===
(function(){
  const s = D.historique_2002_2024.indicateurs.cine_recettes.serie.filter(p => p.valeur != null);
  new Chart(document.getElementById('chart_cine_hist'), {
    type: 'line', data: { labels: s.map(p => p.annee),
      datasets: [{ data: s.map(p => p.valeur/1e6), borderColor: C.bb, backgroundColor: 'rgba(51,101,138,0.12)',
        borderWidth: 2.5, fill: true, tension: 0.35, pointRadius: 0, pointHoverRadius: 5, pointHoverBackgroundColor: C.bb }]},
    options: { responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false },
        tooltip: { callbacks: { label: c => c.parsed.y.toFixed(0) + ' M$' }}},
      scales: { x: { grid: { display: false }},
        y: { grid: { color: '#f0f4f8' }, ticks: { callback: v => v + ' M$' }}}}
