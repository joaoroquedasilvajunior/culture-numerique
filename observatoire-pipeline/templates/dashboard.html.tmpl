      datasets: [{ data, backgroundColor: colors, borderRadius: 6, borderSkipped: false }]},
    options: { indexAxis: 'y', responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false },
        tooltip: { callbacks: { label: c => c.parsed.x.toFixed(1) + ' %' }}},
      scales: { x: { grid: { color: '#f0f4f8' }, ticks: { callback: v => v + ' %' }, max: 25 },
        y: { grid: { display: false }}}}
  });
})();

// === CHART 5: Volume relatif ===
(function(){
  const ind = D.volume_musique.indicateurs;
  const labels = ["Streaming\n(M écoutes)", "Pistes numériques", "Albums total", "Albums physiques", "Albums numériques", "CD", "Vinyle"];
  const keys = ['streaming','pistes_numeriques','albums_total','albums_physiques','albums_numeriques','cd','vinyle'];
  const data = keys.map(k => ind[k] ? ind[k].cumul_ytd : null);
  const display = keys.map((k,i) => k === 'streaming' ? data[i]/1000 : data[i]);
  const colors = keys.map(k => k === 'streaming' ? C.cb : k === 'vinyle' ? C.hb : C.bb);
  new Chart(document.getElementById('chart_volume'), {
    type: 'bar', data: { labels, datasets: [{ data: display, backgroundColor: colors, borderRadius: 6, borderSkipped: false }]},
    options: { indexAxis: 'y', responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false },
        tooltip: { callbacks: { label: c => {
          const v = c.parsed.x;
          if (c.dataIndex === 0) return v.toLocaleString('fr-CA',{maximumFractionDigits:0}) + ' M écoutes';
          return v.toLocaleString('fr-CA',{maximumFractionDigits:1}) + ' k unités';
        }}}},
      scales: { x: { type: 'logarithmic', grid: { color: '#f0f4f8' }, ticks: { callback: v => v.toLocaleString('fr-CA') }},
        y: { grid: { display: false }}}}
  });
})();

// === CHART 6: Cinéma par pays — doughnut ===
(function(){
  const pays = D.cinema_pays_origine.pays.filter(p => p.pays !== 'Total');
  const colors = pays.map(p => p.pays === 'Québec' ? C.bo : p.pays === 'France' ? C.bb : p.pays === 'États-Unis' ? C.cb : p.pays === 'Grande-Bretagne' ? C.sr : p.pays === 'Canada' ? C.hb : C.cb700);
  new Chart(document.getElementById('chart_cine_pays'), {
    type: 'doughnut', data: { labels: pays.map(p => p.pays + ' (' + p.pct_cumul_ytd.toFixed(1) + ' %)'),
      datasets: [{ data: pays.map(p => p.pct_cumul_ytd), backgroundColor: colors, borderWidth: 2, borderColor: '#fff' }]},
    options: { responsive: true, maintainAspectRatio: false, cutout: '60%',
      plugins: { legend: { position: 'right', labels: { boxWidth: 12, padding: 10, font: { size: 11 }, usePointStyle: true }}}}
  });
})();

// === CHART 7: Cinéma variation ===
(function(){
  const pays = D.cinema_pays_origine.pays.filter(p => p.pays !== 'Autres pays');
  const labels = pays.map(p => p.pays);
  const data = pays.map(p => p.var_cumul_an_prec_pct);
  const colors = data.map(v => v < 0 ? C.bo : C.green);
  new Chart(document.getElementById('chart_cine_var'), {
    type: 'bar', data: { labels, datasets: [{ data, backgroundColor: colors, borderRadius: 6, borderSkipped: false }]},
    options: { indexAxis: 'y', responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false },
        tooltip: { callbacks: { label: c => (c.parsed.x >= 0 ? '+' : '') + c.parsed.x.toFixed(1) + ' %' }}},
      scales: { x: { grid: { color: '#f0f4f8' }, ticks: { callback: v => v + ' %' }},
        y: { grid: { display: false }}}}
  });
})();

// === TABLEAU CINEMA ===
(function(){
  const tbody = document.getElementById('tbl_cine');
  const flagMap = {'États-Unis':'us','France':'fr','Grande-Bretagne':'gb','Québec':'qc','Canada':'ca','Autres pays':'other','Total':'other'};
  D.cinema_pays_origine.pays.forEach(p => {
    const tr = document.createElement('tr');
    if (p.pays === 'Québec') tr.className = 'qc';
    const v = p.var_cumul_an_prec_pct;
    const cls = v == null ? '' : (v > 0 ? 'up' : 'down');
    const sign = v == null ? '—' : (v >= 0 ? '+' : '');
    const flag = flagMap[p.pays] || 'other';
    tr.innerHTML = `
      <td><span class="badge-flag ${flag}">${p.pays === 'Total' ? 'TOT' : p.pays.substring(0,2).toUpperCase()}</span></td>
      <td><strong>${p.pays}</strong></td>
      <td class="num">${p.assistance_cumul_ytd ? p.assistance_cumul_ytd.toLocaleString('fr-CA') : '—'}</td>
      <td class="pct">${p.pct_cumul_ytd != null ? p.pct_cumul_ytd.toFixed(1) + ' %' : '—'}</td>
      <td class="pct ${cls}">${v != null ? sign + v.toFixed(1) + ' %' : '—'}</td>`;
    tbody.appendChild(tr);
  });
})();

// === CHART 9: Ventes de livres par catégorie de points de vente ===
(function(){
  const v = D.ventes_categorie;
  const el = document.getElementById('chart_ventes_livres');
  if (!v || !v.lignes || !el) return;
  const find = lbl => v.lignes.find(L => L.libelle === lbl);
  const cats = [
    { lbl: 'Librairies (A+B ou C+D)',                   nom: 'Librairies',       col: C.bb },
    { lbl: 'Éditeurs - marché de la vente finale',      nom: 'Éditeurs',         col: C.cb700 },
    { lbl: 'Distributeurs - marché de la vente finale', nom: 'Distributeurs',    col: C.sr400 },
    { lbl: 'Grande diffusion',                          nom: 'Grande diffusion', col: C.hb },
  ];
  const datasets = cats.map(c => {
    const L = find(c.lbl);
    return { label: c.nom,
      data: L ? L.valeurs.map(x => x == null ? 0 : x / 1e6) : [],
      backgroundColor: c.col, borderRadius: 4, borderSkipped: false };
  });
  new Chart(el, {
    type: 'bar',
    data: { labels: v.mois, datasets },
    options: { responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: { position: 'bottom', labels: { boxWidth: 12, padding: 12, font: { size: 11 }, usePointStyle: true }},
        tooltip: { callbacks: { label: c => c.dataset.label + ' : ' + c.parsed.y.toLocaleString('fr-CA', {maximumFractionDigits: 1}) + ' M$' }}},
      scales: {
        x: { stacked: true, grid: { display: false }},
        y: { stacked: true, grid: { color: '#f0f4f8' }, ticks: { callback: val => val + ' M$' }}}}
  });
  const tot = find('Ventes totales'), agr = find('Librairies agréées (A)');
  const foot = document.getElementById('foot_ventes_livres');
  if (foot && tot && tot.cumul) {
    let txt = 'Cumul 2025 : ' + (tot.cumul / 1e6).toLocaleString('fr-CA', {maximumFractionDigits: 0}) + ' M$.';
    if (agr && agr.cumul) {
      txt += ' Les librairies agréées par le MCC en captent '
        + (agr.cumul / tot.cumul * 100).toLocaleString('fr-CA', {maximumFractionDigits: 1}) + ' %.';
    }
    foot.textContent = txt;
  }
})();

// === CHART 8: Emplois EERH ===
(function(){
  const labelMap = {
    'Distribution de contenu en continu': 'Distribution contenu en continu (5162)',
    'Radiotélévision et fournisseurs de contenu': 'Radiotélévision et fournisseurs (516)',
    'Librairies et marchands de journaux': 'Librairies et marchands (4592)',
    'Industries de l\'enregistrement sonore': 'Enregistrement sonore (5122)',
    'Stations de radiodiffusion et de télédiffusion': 'Stations radio/télé (5161)',
    'Établissements du patrimoine': 'Patrimoine (712, 7121)',
    'Industries du film et de l\'enregistrement sonore': 'Film et enregistrement sonore (512)',
    'Industries du film et de vidéo': 'Film et vidéo (5121)',
    'Compagnies d\'arts d\'interprétation': 'Compagnies d\'arts d\'interprétation (7111)',
    'Éditeurs de journaux, de périodiques, de livres et de répertoires':'Éditeurs (5131)',
    'Services de distribution de contenu médiatique diffusé en continu et autres réseaux et fournisseurs de contenu médiatique':'Distribution contenu en continu (5162)',
  };
  const rows = D.emplois_2025
    .filter(r => r.industrie && r.industrie !== 'Ensemble des industries' && r.industrie !== 'Industries de services')
    .filter(r => r.serie_terminee !== 'True')
    .map(r => ({
      label: labelMap[r.industrie] || (r.industrie + (r.scian ? ' ('+r.scian+')' : '')),
      var_pct: parseFloat(r.variation_pct),
    }))
    .filter(r => !isNaN(r.var_pct))
    .sort((a,b) => a.var_pct - b.var_pct);
  const colors = rows.map(r => r.var_pct < -5 ? C.bo : r.var_pct < 0 ? C.bo600 : r.var_pct > 10 ? C.green : C.bb);
  new Chart(document.getElementById('chart_emplois'), {
    type: 'bar', data: { labels: rows.map(r => r.label),
      datasets: [{ data: rows.map(r => r.var_pct), backgroundColor: colors, borderRadius: 6, borderSkipped: false }]},
    options: { indexAxis: 'y', responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false },
        tooltip: { callbacks: { label: c => (c.parsed.x >= 0 ? '+' : '') + c.parsed.x.toFixed(1) + ' %' }}},
      scales: { x: { grid: { color: '#f0f4f8' }, ticks: { callback: v => v + ' %' }},
        y: { grid: { display: false }}}}
  });
})();

// === SCROLL SPY ===
(function(){
  const navLinks = document.querySelectorAll('.nav a[data-section]');
  const sections = Array.from(navLinks).map(a => document.getElementById(a.dataset.section));
  const setActive = id => {
    navLinks.forEach(a => a.classList.toggle('active', a.dataset.section === id));
  };
  const obs = new IntersectionObserver(entries => {
    const visible = entries.filter(e => e.isIntersecting).sort((a,b) => b.intersectionRatio - a.intersectionRatio);
    if (visible[0]) setActive(visible[0].target.id);
  }, { rootMargin: '-100px 0px -50% 0px', threshold: [0, 0.25, 0.5, 0.75, 1] });
  sections.forEach(s => s && obs.observe(s));
})();

// Smooth-scroll
document.querySelectorAll('.nav a[href^="#"]').forEach(a => {
  a.addEventListener('click', e => {
    e.preventDefault();
    document.getElementById(a.getAttribute('href').slice(1)).scrollIntoView({behavior:'smooth',block:'start'});
  });
});
</script>
