// La dérivation est calculée côté pipeline (src/derive.py:derive_lentille_3_amelioree)
// et exposée dans D.reperes.lentille_3_ameliorée. Statut auxiliaire provisoire,
// hors protocole gelé. Si la donnée est absente (sources EERH ou rémunération
// manquantes), la section reste à l'état statique avec des « — ».
(function(){
  const L3 = D.reperes && D.reperes.lentille_3_ameliorée;
  if (!L3 || !L3.secteurs) return;

  // Helpers
  const fmt = (n, dec) => (n == null) ? '—' : Number(n).toLocaleString('fr-CA',
      {minimumFractionDigits: dec, maximumFractionDigits: dec});
  const setText = (id, val) => { const el = document.getElementById(id);
                                  if (el) el.textContent = val; };
  const setClass = (id, cls) => { const el = document.getElementById(id);
                                  if (el) el.className = cls; };

  function dirClass(v){
    if (v == null) return 'flat';
    if (v >= 2) return 'up';
    if (v <= -2) return 'down';
    return 'flat';
  }
  function fmtVar(v, decimals){
    if (v == null) return '—';
    const signe = v > 0 ? '+' : '';
    return signe + fmt(v, decimals == null ? 2 : decimals).replace('.', ',') + ' %';
  }

  // Libellés conviviaux des verdicts
  const VERDICT_LABEL = {
    'consolidation': 'Consolidation',
    'contraction_nette': 'Contraction nette',
    'expansion_saine': 'Expansion saine',
    'precarisation': 'Précarisation',
    'stable': 'Stable',
    'indeterminee': 'Indéterminée'
  };

  L3.secteurs.forEach(s => {
    const code = s.code_scian;  // '51' ou '71'
    // En-tête : code SCIAN + verdict badge
    setText(`l3-${code}-scian`, `SCIAN [${code}]`);
    setText(`l3-${code}-libelle`, s.libelle);
    const verdict = s.classification || 'indeterminee';
    setText(`l3-${code}-verdict-badge`, VERDICT_LABEL[verdict] || verdict);
    setClass(`l3-${code}-verdict-badge`, `l3-verdict-badge verdict-${verdict}`);
    // Bordure gauche du card par verdict
    setClass(`l3card-${code}`, `l3-card verdict-${verdict}`);

    // Effectifs
    const eff = s.effectifs || {};
    const varEff = eff.variation_pct;
    setText(`l3-${code}-eff-var`, fmtVar(varEff));
    setClass(`l3-${code}-eff-var`, `l3-metric-value ${dirClass(varEff)}`);
    if (eff.moyenne_2024 != null && eff.moyenne_2025 != null) {
      setText(`l3-${code}-eff-sub`,
              `${fmt(eff.moyenne_2024, 0)} → ${fmt(eff.moyenne_2025, 0)} salariés`);
    }

    // Rémunération
    const rem = s.remuneration_hebdo || {};
    const varRem = rem.variation_pct;
    setText(`l3-${code}-rem-var`, fmtVar(varRem));
    setClass(`l3-${code}-rem-var`, `l3-metric-value ${dirClass(varRem)}`);
    if (rem.moyenne_2024 != null && rem.moyenne_2025 != null) {
      setText(`l3-${code}-rem-sub`,
              `${fmt(rem.moyenne_2024, 0)} $ → ${fmt(rem.moyenne_2025, 0)} $ / sem.`);
    }

    // Lecture analytique
    setText(`l3-${code}-lecture`, s.lecture || '');

    // Composantes ISQ niveau 4
    const comp_el = document.getElementById(`l3-${code}-composantes`);
    if (comp_el) {
      comp_el.innerHTML = '';
      (s.composantes_ISQ_niveau_4 || []).forEach(c => {
        const tca = c.tca_2025;
        const tcaClass = tca == null ? 'na' : (tca > 0 ? 'up' : 'down');
        const tcaText = tca == null ? 'TCA n/d' : `TCA ${(tca > 0 ? '+' : '') + tca.toString().replace('.', ',')} %`;
        const row = document.createElement('div');
        row.className = 'l3-composante';
        row.innerHTML = `<span class="scian">[${c.scian}]</span>` +
                        `<span style="flex:1;text-align:left;padding:0 8px;color:var(--text-muted)">${c.industrie.slice(0, 36)}</span>` +
