})();

// === CHART 6: Cinéma par pays — doughnut ===
(function(){
  const pays = D.cinema_pays_origine.pays.filter(p => p.pays !== 'Total');
  const colors = pays.map(p => p.pays === 'Québec' ? C.bo : p.pays === 'France' ? C.bb : p.pays === 'États-Unis' ? C.cb : p.pays === 'Grande-Bretagne' ? C.sr : p.pays === 'Canada' ? C.hb : C.cb700);
