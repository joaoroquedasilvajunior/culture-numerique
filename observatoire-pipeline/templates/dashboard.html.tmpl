<!DOCTYPE html>
<html lang="fr-CA">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Observatoire de la souveraineté culturelle numérique — Tableau de bord</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Nunito:wght@600;700;800&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
:root{
  /* charcoal_blue */
  --cb-100:#090e11; --cb-200:#131c22; --cb-300:#1c2b34; --cb-400:#253945; --cb-500:#2f4858; --cb-600:#496f87; --cb-700:#6c96b0; --cb-800:#9db9ca; --cb-900:#cedce5;
  /* baltic_blue */
  --bb-100:#0a141c; --bb-200:#142837; --bb-300:#1f3c53; --bb-400:#29506e; --bb-500:#33658a; --bb-600:#4486b9; --bb-700:#72a5cb; --bb-800:#a1c3dc; --bb-900:#d0e1ee;
  /* sky_reflection */
  --sr-100:#112935; --sr-200:#22516a; --sr-300:#347a9f; --sr-400:#529ec7; --sr-500:#86bbd8; --sr-600:#a0c9e0; --sr-700:#b7d7e8; --sr-800:#cfe4f0; --sr-900:#e7f2f7;
  /* honey_bronze */
  --hb-100:#382502; --hb-200:#704a05; --hb-300:#a76f07; --hb-400:#df9409; --hb-500:#f6ae2d; --hb-600:#f8bf57; --hb-700:#facf81; --hb-800:#fbdfab; --hb-900:#fdefd5;
  /* blaze_orange */
  --bo-100:#321303; --bo-200:#642706; --bo-300:#963a09; --bo-400:#c84e0c; --bo-500:#f26419; --bo-600:#f48346; --bo-700:#f7a274; --bo-800:#fac1a2; --bo-900:#fce0d1;

  --bg:#f5f7fb;
  --surface:#ffffff;
  --border:#e5ebf2;
  --text:#1c2b34;
  --text-muted:#6c828f;
  --text-soft:#94a3b1;
  --shadow-sm: 0 1px 2px rgba(47,72,88,0.06);
  --shadow-md: 0 4px 12px rgba(47,72,88,0.08);
  --shadow-lg: 0 10px 30px rgba(47,72,88,0.10);
  --radius-sm: 8px;
  --radius: 12px;
  --radius-lg: 16px;
  --sidebar-w: 260px;
}

*{margin:0;padding:0;box-sizing:border-box}
html,body{font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:var(--bg);color:var(--text);line-height:1.55;-webkit-font-smoothing:antialiased}
body{display:flex;min-height:100vh}
a{color:inherit;text-decoration:none}

/* SIDEBAR */
.sidebar{
  width:var(--sidebar-w);
  flex-shrink:0;
  background:linear-gradient(180deg,var(--cb-300) 0%,var(--cb-200) 100%);
  color:var(--cb-900);
  position:sticky;top:0;height:100vh;
  display:flex;flex-direction:column;
  padding:24px 0;
  box-shadow:1px 0 0 var(--cb-200);
  z-index:10;
}
.brand{
  padding:0 24px 24px;
  display:flex;align-items:center;gap:12px;
  border-bottom:1px solid rgba(206,220,229,0.08);
  margin-bottom:20px;
}
.brand-logo{
  width:38px;height:38px;
  background:linear-gradient(135deg,var(--bb-500) 0%,var(--sr-500) 100%);
  border-radius:10px;
  display:flex;align-items:center;justify-content:center;
  font-family:'Nunito',sans-serif;font-weight:800;color:#fff;font-size:18px;
  box-shadow:0 4px 10px rgba(51,101,138,0.3);
}
.brand-text{font-family:'Nunito',sans-serif;font-size:15px;line-height:1.2;color:#fff}
.brand-text strong{display:block;color:var(--sr-500);font-weight:800;font-size:15px;letter-spacing:-0.01em}
.brand-text small{display:block;color:var(--cb-700);font-size:11px;font-weight:500;margin-top:2px}

.nav{padding:0 14px;flex:1;display:flex;flex-direction:column;gap:2px;overflow-y:auto}
.nav-section{font-size:10px;text-transform:uppercase;letter-spacing:0.08em;color:var(--cb-700);padding:14px 12px 6px;font-weight:600}
.nav a{
  display:flex;align-items:center;gap:12px;
  padding:10px 12px;border-radius:8px;
  font-size:13.5px;font-weight:500;color:var(--cb-800);
  transition:all 0.15s;
}
.nav a:hover{background:rgba(255,255,255,0.05);color:#fff}
.nav a.active{
  background:linear-gradient(90deg,var(--bb-500) 0%,var(--bb-400) 100%);
  color:#fff;font-weight:600;
  box-shadow:0 2px 8px rgba(51,101,138,0.3);
}
.nav a svg{width:18px;height:18px;flex-shrink:0;opacity:0.8}
.nav a.active svg{opacity:1}
.nav-num{margin-left:auto;background:rgba(0,0,0,0.15);font-size:11px;padding:2px 8px;border-radius:10px;font-weight:600}

.sidebar-foot{padding:16px 24px;border-top:1px solid rgba(206,220,229,0.08);font-size:11px;color:var(--cb-700);line-height:1.5}
.sidebar-foot strong{color:var(--hb-500);font-weight:700}

/* MAIN */
.main{flex:1;min-width:0;display:flex;flex-direction:column}

/* TOP BAR */
.topbar{
  background:var(--surface);
  border-bottom:1px solid var(--border);
  padding:18px 32px;
  display:flex;align-items:center;justify-content:space-between;gap:24px;
  position:sticky;top:0;z-index:5;
  box-shadow:var(--shadow-sm);
}
.topbar-left{flex:1;min-width:0}
.breadcrumb{font-size:12px;color:var(--text-soft);margin-bottom:4px}
.breadcrumb span{color:var(--text-muted)}
.page-title{font-family:'Nunito',sans-serif;font-size:21px;font-weight:700;color:var(--cb-300);letter-spacing:-0.01em}
.topbar-right{display:flex;align-items:center;gap:14px}
.badge-period{
  background:var(--sr-900);color:var(--sr-200);
  padding:7px 14px;border-radius:20px;
  font-size:12px;font-weight:600;
  display:flex;align-items:center;gap:8px;
  border:1px solid var(--sr-800);
}
.badge-period::before{content:"";width:8px;height:8px;border-radius:50%;background:var(--bb-500);box-shadow:0 0 0 3px rgba(51,101,138,0.2)}

/* AVIS D'INDÉPENDANCE */
.indep-notice{
  margin:0 0 22px;padding:13px 18px;
  background:var(--hb-900);
  border:1px solid var(--hb-700);
  border-left:3px solid var(--hb-400);
  border-radius:var(--radius-sm);
  font-size:12.5px;line-height:1.6;color:var(--cb-400);
}
.indep-notice strong{color:var(--hb-200);font-weight:700}

/* CONTENT */
.content{padding:28px 32px 48px;max-width:1500px;width:100%}

/* SECTIONS */
.section{margin-bottom:36px;scroll-margin-top:90px}
.section-header{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:18px;gap:24px;flex-wrap:wrap}
.section-title{font-family:'Nunito',sans-serif;font-size:20px;font-weight:700;color:var(--cb-300);letter-spacing:-0.01em;display:flex;align-items:center;gap:12px}
.section-title .num{
  display:inline-flex;align-items:center;justify-content:center;
  width:32px;height:32px;border-radius:8px;
  background:linear-gradient(135deg,var(--bb-500),var(--bb-400));
  color:#fff;font-size:14px;font-weight:700;
  box-shadow:0 2px 6px rgba(51,101,138,0.25);
}
.section-sub{font-size:13.5px;color:var(--text-muted);max-width:780px;margin-top:4px;line-height:1.6}
.art-pill{
  display:inline-block;background:var(--hb-900);color:var(--hb-200);
  padding:3px 10px;border-radius:12px;font-size:11px;font-weight:600;
  margin-right:6px;border:1px solid var(--hb-800);
  letter-spacing:0.02em;
}

/* KPI CARDS — Volt Pro style */
.kpi-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:18px}
.kpi{
  background:var(--surface);
  border-radius:var(--radius);
  padding:22px 24px;
  box-shadow:var(--shadow-md);
  position:relative;overflow:hidden;
  border:1px solid var(--border);
  transition:transform 0.2s,box-shadow 0.2s;
}
.kpi:hover{transform:translateY(-2px);box-shadow:var(--shadow-lg)}
.kpi-head{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:14px}
.kpi-icon{
  width:42px;height:42px;border-radius:10px;
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;
}
.kpi-icon svg{width:22px;height:22px}
.kpi-icon.bb{background:var(--bb-900);color:var(--bb-500)}
.kpi-icon.bo{background:var(--bo-900);color:var(--bo-500)}
.kpi-icon.hb{background:var(--hb-900);color:var(--hb-300)}
.kpi-icon.sr{background:var(--sr-900);color:var(--sr-200)}
.kpi-spark{flex:1;margin-left:18px;opacity:0.85}
.kpi-spark svg{display:block;width:100%;max-width:120px;height:36px;margin-left:auto}
.kpi-label{font-size:11.5px;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.06em;font-weight:600;margin-bottom:2px}
.kpi-value{font-family:'Nunito',sans-serif;font-size:32px;font-weight:800;color:var(--cb-300);letter-spacing:-0.02em;line-height:1.1}
.kpi-delta{display:flex;align-items:center;gap:6px;margin-top:8px;font-size:12.5px;font-weight:600}
.kpi-delta.down{color:var(--bo-500)}
.kpi-delta.up{color:#22a06b}
.kpi-delta.neutral{color:var(--text-muted);font-weight:500}
.kpi-delta-arrow{display:inline-block;width:16px;height:16px}
.kpi-context{font-size:12px;color:var(--text-muted);margin-top:6px;line-height:1.4}

/* REPÈRES SUIVIS — Bande des cinq cards (Protocole de l'Observatoire) */
.reperes-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(210px,1fr));
  gap:14px;
}
.repere{
  background:var(--surface);
  border-radius:var(--radius);
  padding:16px 18px;
  box-shadow:var(--shadow-sm);
  border:1px solid var(--border);
  border-left:3px solid var(--text-soft);
  display:flex;flex-direction:column;gap:6px;
  transition:transform 0.2s,box-shadow 0.2s;
  min-height:170px;
}
.repere:hover{transform:translateY(-1px);box-shadow:var(--shadow-md)}
.repere-provisional{border-left-color:var(--hb-400)}
.repere-frozen{border-left-color:var(--bb-500)}
.repere-pending{border-left-color:var(--text-soft);background:linear-gradient(180deg,var(--surface) 0%,#f9fafc 100%)}
.repere-head{display:flex;align-items:center;justify-content:space-between;gap:8px;margin-bottom:2px}
.repere-tag{
  font-family:'Nunito',sans-serif;font-weight:700;font-size:10.5px;
  background:var(--cb-300);color:#fff;padding:3px 8px;border-radius:4px;letter-spacing:0.04em;
}
.repere-status{
  font-size:9.5px;font-weight:600;text-transform:uppercase;letter-spacing:0.04em;
  padding:3px 8px;border-radius:10px;white-space:nowrap;
}
.status-provisional{background:var(--hb-900);color:var(--hb-200);border:1px solid var(--hb-700)}
.status-frozen{background:var(--bb-900);color:var(--bb-300);border:1px solid var(--bb-700)}
.status-pending{background:#f0f2f5;color:var(--text-muted);border:1px solid var(--border)}
.repere-name{font-family:'Nunito',sans-serif;font-size:13.5px;font-weight:700;color:var(--cb-300);line-height:1.3}
.repere-values{display:flex;flex-direction:column;gap:1px;margin-top:2px}
.repere-value-main{
  font-family:'Nunito',sans-serif;font-size:22px;font-weight:800;
  color:var(--cb-300);letter-spacing:-0.02em;line-height:1.1;
}
.repere-pending .repere-value-main{color:var(--text-soft)}
.repere-value-sub{font-size:12.5px;color:var(--text-muted);font-weight:600}
.repere-context{font-size:11.5px;color:var(--text-muted);line-height:1.4;margin-top:2px}
.repere-source{
  font-size:10.5px;color:var(--text-soft);font-style:italic;
  margin-top:auto;padding-top:6px;border-top:1px dashed var(--border);
}
.protocole-badge{
  background:var(--bb-900);color:var(--bb-300);
  padding:7px 13px;border-radius:20px;
  font-size:11.5px;font-weight:700;letter-spacing:0.02em;
  border:1px solid var(--bb-700);
  display:inline-flex;align-items:center;gap:7px;
  white-space:nowrap;
}
.protocole-badge::before{
  content:"";width:8px;height:8px;border-radius:50%;background:var(--bb-500);
  box-shadow:0 0 0 3px rgba(51,101,138,0.2);
}
.reperes-note{
  margin-top:16px;padding:12px 18px;
  background:var(--sr-900);
  border:1px solid var(--sr-800);
  border-left:3px solid var(--sr-400);
  border-radius:var(--radius-sm);
  font-size:12px;line-height:1.55;color:var(--cb-400);
}
.reperes-note strong{color:var(--cb-300);font-weight:700}
.reperes-note a{color:var(--bb-500);font-weight:600;text-decoration:underline}
.section-title .star{
  display:inline-flex;align-items:center;justify-content:center;
  width:32px;height:32px;border-radius:8px;
  background:linear-gradient(135deg,var(--hb-400),var(--bo-500));
  color:#fff;font-size:16px;font-weight:700;
  box-shadow:0 2px 6px rgba(248,191,87,0.35);
}

/* TIMELINE */
.timeline-wrap{
  background:var(--surface);border-radius:var(--radius);padding:24px 28px;
  box-shadow:var(--shadow-md);border:1px solid var(--border);
}
.timeline{display:grid;grid-template-columns:repeat(7,1fr);gap:8px;position:relative;margin-top:8px}
.timeline::before{
  content:"";position:absolute;top:14px;left:6%;right:6%;height:2px;
  background:linear-gradient(90deg,var(--cb-700) 0%,var(--bb-500) 70%,var(--bo-500) 90%,var(--cb-700) 100%);
  z-index:0;border-radius:2px;
}
.tl-item{position:relative;z-index:1;text-align:center;padding:0 4px}
.tl-dot{width:14px;height:14px;border-radius:50%;background:var(--bb-500);margin:0 auto 10px;border:3px solid var(--surface);box-shadow:0 0 0 2px var(--bb-500)}
.tl-item.key .tl-dot{background:var(--bo-500);box-shadow:0 0 0 2px var(--bo-500),0 0 0 6px rgba(242,100,25,0.18)}
.tl-yr{font-family:'Nunito',sans-serif;font-weight:800;font-size:13px;color:var(--bb-500)}
.tl-item.key .tl-yr{color:var(--bo-500)}
.tl-lbl{font-size:11px;color:var(--text-muted);margin-top:4px;line-height:1.35}
.tl-item.key .tl-lbl strong{color:var(--cb-300)}

/* QUOTE CARD */
.quote{
  background:linear-gradient(135deg,var(--bb-900) 0%,var(--sr-900) 100%);
  border-left:4px solid var(--bb-500);
  border-radius:0 var(--radius) var(--radius) 0;
  padding:18px 22px;
  margin-top:18px;
  font-size:14px;
  line-height:1.65;
  color:var(--bb-300);
  position:relative;
}
.quote::before{
  content:"❝";position:absolute;top:0;right:18px;
  font-family:Georgia,serif;font-size:60px;color:var(--bb-700);opacity:0.3;line-height:1;
}
.quote em{font-style:italic;color:var(--cb-300)}
.quote-att{display:block;margin-top:8px;font-size:12px;color:var(--text-muted);font-style:italic}

/* CARDS / CHART CONTAINERS */
.row{display:grid;gap:20px;margin-top:20px}
.row-2{grid-template-columns:1fr 1fr}
.row-3{grid-template-columns:repeat(3,1fr)}
.row-1-2{grid-template-columns:1fr 2fr}
.row-2-1{grid-template-columns:2fr 1fr}
@media (max-width:1100px){.row-2,.row-3,.row-1-2,.row-2-1{grid-template-columns:1fr}}

.card{
  background:var(--surface);border-radius:var(--radius);
  border:1px solid var(--border);box-shadow:var(--shadow-sm);
  overflow:hidden;
  transition:box-shadow 0.2s;
}
.card:hover{box-shadow:var(--shadow-md)}
.card-head{
  padding:18px 22px 12px;
  display:flex;align-items:flex-start;justify-content:space-between;gap:12px;
  border-bottom:1px solid var(--border);
}
.card-title{font-family:'Nunito',sans-serif;font-size:15px;font-weight:700;color:var(--cb-300);letter-spacing:-0.01em}
.card-sub{font-size:11.5px;color:var(--text-muted);margin-top:3px}
.card-body{padding:18px 22px}
.card-foot{padding:10px 22px 14px;font-size:11.5px;color:var(--text-muted);font-style:italic;border-top:1px solid var(--border);background:#fafbfc}

.chart-wrap{position:relative;height:280px}
.chart-wrap.tall{height:380px}
.chart-wrap.short{height:220px}

/* TOP 20 GRID */
.top20{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:8px}
.t20{display:flex;align-items:center;gap:10px;padding:10px 12px;background:var(--bg);border:1px solid var(--border);border-radius:var(--radius-sm);transition:all 0.15s;font-size:13px}
.t20:hover{border-color:var(--cb-700);background:#fff}
.t20.qc{
  background:linear-gradient(90deg,var(--hb-900) 0%,#fff 100%);
  border-color:var(--hb-500);
  font-weight:600;
  box-shadow:0 0 0 2px rgba(246,174,45,0.12);
}
.t20-rank{
  width:26px;height:26px;border-radius:6px;
  background:var(--cb-300);color:#fff;
  display:flex;align-items:center;justify-content:center;
  font-weight:700;font-size:11px;flex-shrink:0;
}
.t20.qc .t20-rank{background:var(--bo-500)}
.t20-name{flex:1;font-size:13px;color:var(--text)}
.t20-prov{font-size:10px;text-transform:uppercase;letter-spacing:0.04em;color:var(--text-soft);font-weight:600}
.t20.qc .t20-prov{color:var(--bo-300)}

/* TABLES */
.tbl{width:100%;border-collapse:collapse;font-size:13px}
.tbl thead th{
  text-align:left;padding:12px 18px;
  background:var(--cb-300);color:#fff;
  font-weight:600;font-size:11px;letter-spacing:0.06em;text-transform:uppercase;
}
.tbl thead th:first-child{border-top-left-radius:var(--radius-sm)}
.tbl thead th:last-child{border-top-right-radius:var(--radius-sm)}
.tbl tbody td{padding:11px 18px;border-bottom:1px solid var(--border);font-variant-numeric:tabular-nums}
.tbl tbody tr:last-child td{border-bottom:none}
.tbl tbody tr:hover{background:var(--sr-900)}
.tbl tbody tr.qc{background:linear-gradient(90deg,var(--hb-900) 0%,#fff 60%);font-weight:600}
.tbl .num{text-align:right}
.tbl .pct{text-align:right;font-weight:600}
.tbl .pct.up{color:#22a06b}
.tbl .pct.down{color:var(--bo-500)}
.badge-flag{display:inline-flex;align-items:center;gap:4px;padding:3px 8px;border-radius:8px;font-size:10.5px;font-weight:700;letter-spacing:0.04em;text-transform:uppercase}
.badge-flag.qc{background:var(--bo-500);color:#fff}
.badge-flag.us{background:var(--cb-300);color:#fff}
.badge-flag.fr{background:var(--bb-500);color:#fff}
.badge-flag.gb{background:var(--sr-300);color:#fff}
.badge-flag.ca{background:var(--hb-500);color:var(--cb-200)}
.badge-flag.other{background:var(--text-soft);color:#fff}

/* BLIND SPOTS — accordion-style cards */
.blind-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(290px,1fr));gap:18px;margin-top:8px}
.blind{
  background:var(--surface);border-radius:var(--radius);
  border:1px solid var(--border);padding:20px 22px;
  position:relative;border-left:4px solid var(--hb-500);
  transition:transform 0.15s;
}
.blind:hover{transform:translateY(-2px);box-shadow:var(--shadow-md)}
.blind-head{display:flex;align-items:center;gap:10px;margin-bottom:10px}
.blind-icon{
  width:34px;height:34px;background:var(--hb-900);color:var(--hb-300);
  border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;
}
.blind-icon svg{width:18px;height:18px}
.blind h4{font-family:'Nunito',sans-serif;font-size:14.5px;color:var(--cb-300);font-weight:700;letter-spacing:-0.01em}
.blind p{font-size:13px;color:var(--text);line-height:1.55;margin:0 0 10px}
.blind .ref{display:block;font-size:11px;color:var(--text-muted);font-style:italic;padding-top:8px;border-top:1px dashed var(--border)}

/* INSIGHT CALLOUT */
.insight{
  background:var(--surface);border-radius:var(--radius);padding:22px 26px;
  border:1px solid var(--border);box-shadow:var(--shadow-sm);
  display:flex;gap:18px;align-items:flex-start;margin-top:20px;
}
.insight-icon{
  width:44px;height:44px;border-radius:10px;flex-shrink:0;
  background:linear-gradient(135deg,var(--bo-500),var(--hb-500));
  color:#fff;display:flex;align-items:center;justify-content:center;
}
.insight-icon svg{width:24px;height:24px}
.insight h3{font-family:'Nunito',sans-serif;font-size:15px;color:var(--cb-300);font-weight:700;margin-bottom:6px}
.insight p{font-size:13.5px;color:var(--text);line-height:1.6}

/* FOOTER */
.dashboard-foot{
  background:var(--cb-200);color:var(--cb-800);
  padding:32px;font-size:12.5px;line-height:1.65;margin-top:40px;
}
.dashboard-foot .grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:32px;max-width:1500px;margin:0 auto}
.dashboard-foot h5{color:#fff;font-family:'Nunito',sans-serif;margin-bottom:8px;font-size:13px;text-transform:uppercase;letter-spacing:0.06em}
.dashboard-foot a{color:var(--sr-500)}
.dashboard-foot .small{color:var(--cb-700);font-size:11px;margin-top:8px}

/* RESPONSIVE */
@media (max-width:900px){
  body{display:block}
  .sidebar{position:relative;width:100%;height:auto;flex-direction:row;padding:12px 16px;align-items:center;gap:14px;overflow-x:auto}
  .sidebar .brand{padding:0;border:none;margin:0}
  .nav{flex-direction:row;padding:0;flex-wrap:nowrap;overflow-x:auto;gap:6px}
  .nav-section,.sidebar-foot{display:none}
  .nav a{white-space:nowrap;padding:8px 12px;font-size:12.5px}
  .topbar{flex-direction:column;align-items:flex-start;gap:10px;padding:14px 16px;position:static}
  .topbar-left,.topbar-right{width:100%}
  .timeline{grid-template-columns:repeat(4,1fr)}
  .timeline::before{display:none}
  .content{padding:20px 16px 32px}
}

@media (max-width:560px){
  .page-title{font-size:18px;line-height:1.25}
  .section-title{font-size:17px}
  .section-header{gap:10px}
  .timeline{grid-template-columns:repeat(2,1fr)}
  .badge-period{font-size:11px;padding:6px 12px}
  .kpi-grid{gap:12px}
}

/* PRINT */
@media print{
  .sidebar,.topbar{display:none}
  body{background:#fff;display:block}
  .main{display:block}
  .content{padding:20px;max-width:none}
  .section{break-inside:avoid;page-break-inside:avoid}
  .card{box-shadow:none;border:1px solid var(--border)}
}
</style>
