// === LENTILLE 1b DEMANDE MARCHÉ — Population des deux cards (Québec JVWS) ===
// La donnée vient de l'extracteur extract_job_vacancy_quebec (src/extract.py)
// qui filtre la table CANSIM 14-10-0442 sur GÉO='Québec' et les 6 sous-secteurs
// SCIAN culture (512, 513, 516, 519, 711, 712). Si la donnée est absente, la
// section reste à l'état statique avec des « — ».
(function(){
  const L1b = D.reperes && D.reperes.lentille_1b_demande_marche;
  if (!L1b || !L1b.secteurs) return;

  const fmt = (n, dec) => (n == null) ? '—' : Number(n).toLocaleString('fr-CA',
      {minimumFractionDigits: dec, maximumFractionDigits: dec});

  // Classification des taux de postes vacants
  function tensionClass(taux){
    if (taux == null) return 'tension-na';
    if (taux >= 4) return 'tension-elevee';
    if (taux >= 2) return 'tension-modere';
    return 'tension-faible';
  }
  // Classification salaire (relatif aux extrêmes du périmètre)
  function salClass(sal, min, max){
    if (sal == null || min == null || max == null) return 'sal-moyen';
    const range = max - min;
    if (range <= 0) return 'sal-moyen';
    const pos = (sal - min) / range;
    if (pos >= 0.66) return 'sal-eleve';
    if (pos <= 0.33) return 'sal-bas';
    return 'sal-moyen';
  }

  // Préparer les secteurs couverts (avec données)
  const couverts = L1b.secteurs.filter(s => !s.statut || s.statut !== 'non_couvert');
  const nonCouverts = L1b.secteurs.filter(s => s.statut === 'non_couvert');

  // --- Card 1 : Tension de marché (trié par taux décroissant) ---
  const tensionData = couverts.map(s => ({
    code: s.code_scian,
    libelle: s.libelle,
    taux: s.moyennes_5_derniers_trimestres.taux_postes_vacants,
  })).sort((a, b) => (b.taux || 0) - (a.taux || 0));

  // Échelle de barre : max théorique 6 % pour le périmètre culture
  const tauxMaxAffichage = 6;

  const tensionEl = document.getElementById('l1b-tension-rows');
  if (tensionEl) {
    tensionEl.innerHTML = '';
    tensionData.forEach(item => {
      const row = document.createElement('div');
      row.className = 'l1b-row' + (item.taux == null ? ' absent' : '');
      const cls = tensionClass(item.taux);
      const widthPct = item.taux == null ? 0 : Math.min(100, (item.taux / tauxMaxAffichage) * 100);
      const label = item.taux == null ? '' : (Math.round(item.taux * 10) / 10).toString().replace('.', ',') + ' %';
      row.innerHTML = `
        <div class="scian">${item.code}</div>
        <div class="libelle">${item.libelle.slice(0, 50)}</div>
        <div class="bar-cell"><div class="bar-fill ${cls}" style="width:${widthPct}%">${widthPct >= 25 ? label : ''}</div></div>
        <div class="metric">${item.taux == null ? '—' : fmt(item.taux, 1).replace('.', ',') + ' %'}</div>`;
      tensionEl.appendChild(row);
    });
    // Lignes non couvertes en bas
    nonCouverts.forEach(s => {
      const row = document.createElement('div');
      row.className = 'l1b-row absent';
      row.innerHTML = `
        <div class="scian">${s.code_scian}</div>
        <div class="libelle">${s.libelle.slice(0, 50)} <em>(série archivée)</em></div>
        <div class="bar-cell"></div>
        <div class="metric">—</div>`;
      tensionEl.appendChild(row);
    });
  }

  // --- Card 2 : Salaire horaire offert (trié par salaire décroissant) ---
  const salData = couverts.map(s => ({
    code: s.code_scian,
    libelle: s.libelle,
    sal: s.moyennes_5_derniers_trimestres.salaire_horaire_offert,
  })).sort((a, b) => (b.sal || 0) - (a.sal || 0));

  const salValid = salData.map(d => d.sal).filter(v => v != null);
  const salMin = salValid.length ? Math.min(...salValid) : null;
  const salMax = salValid.length ? Math.max(...salValid) : null;
  // Échelle barre : 0 à salMax + 5 $
  const salBarMax = salMax ? salMax + 5 : 50;

  const salaireEl = document.getElementById('l1b-salaire-rows');
  if (salaireEl) {
    salaireEl.innerHTML = '';
    salData.forEach(item => {
      const row = document.createElement('div');
      row.className = 'l1b-row' + (item.sal == null ? ' absent' : '');
      const cls = salClass(item.sal, salMin, salMax);
      const widthPct = item.sal == null ? 0 : Math.min(100, (item.sal / salBarMax) * 100);
      const label = item.sal == null ? '' : Math.round(item.sal) + ' $';
      row.innerHTML = `
        <div class="scian">${item.code}</div>
        <div class="libelle">${item.libelle.slice(0, 50)}</div>
        <div class="bar-cell"><div class="bar-fill ${cls}" style="width:${widthPct}%">${widthPct >= 30 ? label : ''}</div></div>
        <div class="metric">${item.sal == null ? '—' : fmt(item.sal, 2).replace('.', ',') + ' $'}</div>`;
      salaireEl.appendChild(row);
    });
    nonCouverts.forEach(s => {
      const row = document.createElement('div');
      row.className = 'l1b-row absent';
      row.innerHTML = `
        <div class="scian">${s.code_scian}</div>
        <div class="libelle">${s.libelle.slice(0, 50)} <em>(série archivée)</em></div>
        <div class="bar-cell"></div>
        <div class="metric">—</div>`;
      salaireEl.appendChild(row);
    });
  }
})();

// === SPARKLINES (SVG inline) ===
function spark(elId, points, color) {
  const w = 120, h = 36;
  const max = Math.max(...points), min = Math.min(...points);
  const range = max - min || 1;
  const step = w / (points.length - 1);
  const path = points.map((v, i) => `${i * step},${h - ((v - min) / range) * (h - 6) - 3}`).join(' L');
  const area = `M0,${h} L${path} L${w},${h} Z`;
  const line = `M${path}`;
  const lastY = h - ((points[points.length-1] - min) / range) * (h - 6) - 3;
  const svg = `<svg viewBox="0 0 ${w} ${h}" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
    <defs><linearGradient id="g_${elId}" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="${color}" stop-opacity="0.25"/>
      <stop offset="100%" stop-color="${color}" stop-opacity="0"/>
    </linearGradient></defs>
    <path d="${area}" fill="url(#g_${elId})"/>
    <path d="${line}" stroke="${color}" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
    <circle cx="${w}" cy="${lastY}" r="2.5" fill="${color}"/>
  </svg>`;
  document.getElementById(elId).innerHTML = svg;
}

