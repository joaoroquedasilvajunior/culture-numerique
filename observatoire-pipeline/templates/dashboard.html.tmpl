// === CHART 3 bis : Projections cinéma par langue (série longue 1985-2025) ===
// Stacked bar de la ventilation Langue française vs Autres que le français.
// Source : cinema_langue (ISQ, mise à jour 9 juin 2026).
(function(){
  if (!D.cinema_langue || !D.cinema_langue.indicateurs) return;
  const inds = D.cinema_langue.indicateurs;
  const fr = inds.find(i => i.libelle === 'Langue française' && i.niveau === 0);
  const autres = inds.find(i => i.libelle === 'Autres que le français' && i.niveau === 0);
  const tot = inds.find(i => i.libelle === 'Projections' && i.niveau === 0);
  if (!fr || !autres || !tot) return;
  const annees = tot.serie.map(p => p.annee);
  // Convertir en milliers pour échelle lisible
  const sFr = fr.serie.map(p => p.valeur != null ? p.valeur / 1000 : null);
  const sAutres = autres.serie.map(p => p.valeur != null ? p.valeur / 1000 : null);
  new Chart(document.getElementById('chart_cine_langue'), {
    type: 'bar',
    data: {
      labels: annees,
      datasets: [
        { label: 'Langue française', data: sFr, backgroundColor: C.bb,
          borderColor: C.bb400, borderWidth: 0, stack: 'projections' },
        { label: 'Autres que le français', data: sAutres, backgroundColor: C.cb800,
          borderColor: C.cb700, borderWidth: 0, stack: 'projections' },
      ],
    },
    options: { responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: { display: true, position: 'top', align: 'end',
          labels: { boxWidth: 12, boxHeight: 12, font: {size: 11.5}, padding: 12 }},
        tooltip: { callbacks: {
          label: ctx => {
            const idx = ctx.dataIndex;
            const fVal = sFr[idx] || 0, aVal = sAutres[idx] || 0;
            const total = fVal + aVal;
            const pct = total ? (ctx.dataset.data[idx] / total * 100).toFixed(1).replace('.', ',') + ' %' : '—';
            return ctx.dataset.label + ' : ' + (ctx.dataset.data[idx] || 0).toLocaleString('fr-CA',{maximumFractionDigits:0}) + ' k (' + pct + ')';
          },
          footer: items => {
            const idx = items[0].dataIndex;
            const total = (sFr[idx] || 0) + (sAutres[idx] || 0);
            return 'Total : ' + total.toLocaleString('fr-CA',{maximumFractionDigits:0}) + ' k projections';
          },
        }},
      },
      scales: {
        x: { stacked: true, grid: { display: false }, ticks: { autoSkip: true, maxRotation: 0, font: {size: 10.5} }},
        y: { stacked: true, grid: { color: '#f0f4f8' },
          ticks: { callback: v => v.toLocaleString('fr-CA') + ' k' }},
      },
    },
  });
})();

// === TOP 20 ===
