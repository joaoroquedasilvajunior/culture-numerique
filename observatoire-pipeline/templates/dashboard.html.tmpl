})();

// === CHART 3: Scene representations ===
(function(){
  const s = D.historique_2002_2024.indicateurs.scene_representations.serie.filter(p => p.valeur != null);
  new Chart(document.getElementById('chart_scene_hist'), {
    type: 'line', data: { labels: s.map(p => p.annee),
      datasets: [{ data: s.map(p => p.valeur), borderColor: C.hb, backgroundColor: 'rgba(246,174,45,0.15)',
        borderWidth: 2.5, fill: true, tension: 0.35, pointRadius: 0, pointHoverRadius: 5, pointHoverBackgroundColor: C.hb }]},
    options: { responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false }},
      scales: { x: { grid: { display: false }},
        y: { grid: { color: '#f0f4f8' }, ticks: { callback: v => v.toLocaleString('fr-CA') }}}}
