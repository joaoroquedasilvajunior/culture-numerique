// === CHART 7: Cinéma variation ===
(function(){
  const pays = D.cinema_pays_origine.pays.filter(p => p.pays !== 'Autres pays');
  const labels = pays.map(p => p.pays);
  const data = pays.map(p => p.var_cumul_an_prec_pct);
