        <h5>Méthodologie</h5>
        <p>Données hebdomadaires indicatives ; pour des analyses pluriannuelles, utiliser les séries annuelles. Les emplois EERH excluent les travailleurs autonomes.</p>
        <p class="small">Compilation indépendante. N'engage pas l'ISQ ni le MCC. Données figées au 2 mai 2026 — les chiffres ISQ sont révisés à chaque mise à jour.</p>
      </div>
    </div>
  </footer>
</main>

<script>
const D = __DASHBOARD_DATA__;

// Chart defaults
Chart.defaults.font.family = 'Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif';
Chart.defaults.font.size = 11.5;
Chart.defaults.color = '#6c828f';
Chart.defaults.plugins.tooltip.backgroundColor = '#2f4858';
Chart.defaults.plugins.tooltip.titleColor = '#fff';
Chart.defaults.plugins.tooltip.bodyColor = '#cedce5';
Chart.defaults.plugins.tooltip.padding = 10;
Chart.defaults.plugins.tooltip.cornerRadius = 8;
Chart.defaults.plugins.tooltip.titleFont = {family: 'Nunito', weight: '700', size: 12};
Chart.defaults.plugins.tooltip.bodyFont = {size: 12};

const C = {
  cb: '#2f4858', cb300: '#1c2b34', cb600: '#496f87', cb700: '#6c96b0', cb800: '#9db9ca',
  bb: '#33658a', bb400: '#29506e', bb600: '#4486b9', bb700: '#72a5cb',
  sr: '#86bbd8', sr300: '#347a9f', sr400: '#529ec7', sr800: '#cfe4f0',
  hb: '#f6ae2d', hb300: '#a76f07', hb600: '#f8bf57',
  bo: '#f26419', bo400: '#c84e0c', bo600: '#f48346',
  green: '#22a06b',
};

// === SPARKLINES (SVG inline) ===
function spark(elId, points, color) {
  const w = 120, h = 36;
  const max = Math.max(...points), min = Math.min(...points);
  const range = max - min || 1;
  const step = w / (points.length - 1);
  const path = points.map((v, i) => `${i * step},${h - ((v - min) / range) * (h - 6) - 3}`).join(' L');
  const area = `M0,${h} L${path} L${w},${h} Z`;
  const line = `M${path}`;
  const lastY = h - ((points[points.length-1] - min) / range) * (h - 6) - 3;
  const svg = `<svg viewBox="0 0 ${w} ${h}" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
    <defs><linearGradient id="g_${elId}" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="${color}" stop-opacity="0.25"/>
      <stop offset="100%" stop-color="${color}" stop-opacity="0"/>
    </linearGradient></defs>
    <path d="${area}" fill="url(#g_${elId})"/>
    <path d="${line}" stroke="${color}" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
    <circle cx="${w}" cy="${lastY}" r="2.5" fill="${color}"/>
  </svg>`;
  document.getElementById(elId).innerHTML = svg;
}

// Compute spark series from historical data
const stream_hist = D.historique_2002_2024.indicateurs.musique_streaming.serie.filter(p => p.valeur != null).map(p => p.valeur/1000);
spark('spark1', stream_hist, C.bo);

const cine_pays = D.cinema_pays_origine.pays.filter(p => p.pays === 'Québec')[0];
spark('spark2', [12, 9, 8, 6, 5, 4.7], C.bo);

spark('spark3', [4, 3, 2, 1, 1, 1], C.hb);

// Emplois 5121
const emp5121 = D.emplois_2025.find(e => e.scian === '5121');
spark('spark4', [0, -2, -4, -7, -10, -11.6], C.bo);

// === CHART 1: Streaming historique ===
(function(){
  const s = D.historique_2002_2024.indicateurs.musique_streaming.serie.filter(p => p.valeur != null);
  new Chart(document.getElementById('chart_streaming_hist'), {
    type: 'bar',
    data: { labels: s.map(p => p.annee),
      datasets: [{ data: s.map(p => p.valeur/1000), backgroundColor: ctx => {
        const v = s[ctx.dataIndex].valeur/1000;
        return v < 10000 ? C.sr : v < 25000 ? C.bb : C.cb;
      }, borderRadius: 6, borderSkipped: false }]},
    options: { responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false },
        tooltip: { callbacks: { label: c => c.parsed.y.toLocaleString('fr-CA',{maximumFractionDigits:0}) + ' M écoutes' }}},
      scales: { x: { grid: { display: false }},
        y: { grid: { color: '#f0f4f8' }, ticks: { callback: v => v.toLocaleString('fr-CA') + ' M' }}}}
  });
})();

// === CHART 2: Cinéma recettes historiques ===
(function(){
  const s = D.historique_2002_2024.indicateurs.cine_recettes.serie.filter(p => p.valeur != null);
  new Chart(document.getElementById('chart_cine_hist'), {
    type: 'line', data: { labels: s.map(p => p.annee),
      datasets: [{ data: s.map(p => p.valeur/1e6), borderColor: C.bb, backgroundColor: 'rgba(51,101,138,0.12)',
        borderWidth: 2.5, fill: true, tension: 0.35, pointRadius: 0, pointHoverRadius: 5, pointHoverBackgroundColor: C.bb }]},
    options: { responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false },
        tooltip: { callbacks: { label: c => c.parsed.y.toFixed(0) + ' M$' }}},
      scales: { x: { grid: { display: false }},
        y: { grid: { color: '#f0f4f8' }, ticks: { callback: v => v + ' M$' }}}}
  });
})();

// === CHART 3: Scene representations ===
(function(){
  const s = D.historique_2002_2024.indicateurs.scene_representations.serie.filter(p => p.valeur != null);
  new Chart(document.getElementById('chart_scene_hist'), {
    type: 'line', data: { labels: s.map(p => p.annee),
      datasets: [{ data: s.map(p => p.valeur), borderColor: C.hb, backgroundColor: 'rgba(246,174,45,0.15)',
        borderWidth: 2.5, fill: true, tension: 0.35, pointRadius: 0, pointHoverRadius: 5, pointHoverBackgroundColor: C.hb }]},
    options: { responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false }},
      scales: { x: { grid: { display: false }},
        y: { grid: { color: '#f0f4f8' }, ticks: { callback: v => v.toLocaleString('fr-CA') }}}}
  });
})();

// === TOP 20 ===
(function(){
  const wrap = document.getElementById('top20');
  D.palmares_top20.forEach(t => {
    const isQc = t.provenance === 'Québec';
    const div = document.createElement('div');
    div.className = 't20' + (isQc ? ' qc' : '');
    div.innerHTML = `<span class="t20-rank">${t.rang}</span><span class="t20-name">${t.interprete}</span><span class="t20-prov">${t.provenance}</span>`;
    wrap.appendChild(div);
  });
})();

// === CHART 4: Part QC par canal ===
(function(){
  const ind = D.part_qc_musique.indicateurs;
  const order = ['streaming','albums_physiques','pistes_numeriques','albums_total','albums_numeriques'];
  const labels = {streaming:'Streaming', albums_physiques:'Albums physiques', pistes_numeriques:'Pistes numériques', albums_total:'Tous albums', albums_numeriques:'Albums numériques'};
  const data = order.map(k => ind[k] ? ind[k].cumul_ytd_pct : null);
  const colors = data.map(v => v < 8 ? C.bo : v < 15 ? C.hb : C.bb);
  new Chart(document.getElementById('chart_part_qc'), {
    type: 'bar', data: {labels: order.map(k => labels[k]),
      datasets: [{ data, backgroundColor: colors, borderRadius: 6, borderSkipped: false }]},
    options: { indexAxis: 'y', responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false },
        tooltip: { callbacks: { label: c => c.parsed.x.toFixed(1) + ' %' }}},
      scales: { x: { grid: { color: '#f0f4f8' }, ticks: { callback: v => v + ' %' }, max: 25 },
        y: { grid: { display: false }}}}
  });
})();

// === CHART 5: Volume relatif ===
(function(){
  const ind = D.volume_musique.indicateurs;
  const labels = ["Streaming\n(M écoutes)", "Pistes numériques", "Albums total", "Albums physiques", "Albums numériques", "CD", "Vinyle"];
  const keys = ['streaming','pistes_numeriques','albums_total','albums_physiques','albums_numeriques','cd','vinyle'];
  const data = keys.map(k => ind[k] ? ind[k].cumul_ytd : null);
  const display = keys.map((k,i) => k === 'streaming' ? data[i]/1000 : data[i]);
  const colors = keys.map(k => k === 'streaming' ? C.cb : k === 'vinyle' ? C.hb : C.bb);
  new Chart(document.getElementById('chart_volume'), {
    type: 'bar', data: { labels, datasets: [{ data: display, backgroundColor: colors, borderRadius: 6, borderSkipped: false }]},
    options: { indexAxis: 'y', responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false },
        tooltip: { callbacks: { label: c => {
          const v = c.parsed.x;
          if (c.dataIndex === 0) return v.toLocaleString('fr-CA',{maximumFractionDigits:0}) + ' M écoutes';
          return v.toLocaleString('fr-CA',{maximumFractionDigits:1}) + ' k unités';
        }}}},
      scales: { x: { type: 'logarithmic', grid: { color: '#f0f4f8' }, ticks: { callback: v => v.toLocaleString('fr-CA') }},
        y: { grid: { display: false }}}}
  });
})();

// === CHART 6: Cinéma par pays — doughnut ===
(function(){
  const pays = D.cinema_pays_origine.pays.filter(p => p.pays !== 'Total');
  const colors = pays.map(p => p.pays === 'Québec' ? C.bo : p.pays === 'France' ? C.bb : p.pays === 'États-Unis' ? C.cb : p.pays === 'Grande-Bretagne' ? C.sr : p.pays === 'Canada' ? C.hb : C.cb700);
  new Chart(document.getElementById('chart_cine_pays'), {
    type: 'doughnut', data: { labels: pays.map(p => p.pays + ' (' + p.pct_cumul_ytd.toFixed(1) + ' %)'),
      datasets: [{ data: pays.map(p => p.pct_cumul_ytd), backgroundColor: colors, borderWidth: 2, borderColor: '#fff' }]},
    options: { responsive: true, maintainAspectRatio: false, cutout: '60%',
      plugins: { legend: { position: 'right', labels: { boxWidth: 12, padding: 10, font: { size: 11 }, usePointStyle: true }}}}
  });
})();

// === CHART 7: Cinéma variation ===
(function(){
  const pays = D.cinema_pays_origine.pays.filter(p => p.pays !== 'Autres pays');
  const labels = pays.map(p => p.pays);
  const data = pays.map(p => p.var_cumul_an_prec_pct);
  const colors = data.map(v => v < 0 ? C.bo : C.green);
  new Chart(document.getElementById('chart_cine_var'), {
    type: 'bar', data: { labels, datasets: [{ data, backgroundColor: colors, borderRadius: 6, borderSkipped: false }]},
    options: { indexAxis: 'y', responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false },
        tooltip: { callbacks: { label: c => (c.parsed.x >= 0 ? '+' : '') + c.parsed.x.toFixed(1) + ' %' }}},
      scales: { x: { grid: { color: '#f0f4f8' }, ticks: { callback: v => v + ' %' }},
        y: { grid: { display: false }}}}
  });
})();

// === TABLEAU CINEMA ===
(function(){
  const tbody = document.getElementById('tbl_cine');
  const flagMap = {'États-Unis':'us','France':'fr','Grande-Bretagne':'gb','Québec':'qc','Canada':'ca','Autres pays':'other','Total':'other'};
  D.cinema_pays_origine.pays.forEach(p => {
    const tr = document.createElement('tr');
    if (p.pays === 'Québec') tr.className = 'qc';
    const v = p.var_cumul_an_prec_pct;
    const cls = v == null ? '' : (v > 0 ? 'up' : 'down');
    const sign = v == null ? '—' : (v >= 0 ? '+' : '');
    const flag = flagMap[p.pays] || 'other';
    tr.innerHTML = `
      <td><span class="badge-flag ${flag}">${p.pays === 'Total' ? 'TOT' : p.pays.substring(0,2).toUpperCase()}</span></td>
      <td><strong>${p.pays}</strong></td>
      <td class="num">${p.assistance_cumul_ytd ? p.assistance_cumul_ytd.toLocaleString('fr-CA') : '—'}</td>
      <td class="pct">${p.pct_cumul_ytd != null ? p.pct_cumul_ytd.toFixed(1) + ' %' : '—'}</td>
      <td class="pct ${cls}">${v != null ? sign + v.toFixed(1) + ' %' : '—'}</td>`;
    tbody.appendChild(tr);
  });
})();

// === CHART 8: Emplois EERH ===
(function(){
  const labelMap = {
    'Distribution de contenu en continu': 'Distribution contenu en continu (5162)',
    'Radiotélévision et fournisseurs de contenu': 'Radiotélévision et fournisseurs (516)',
    'Librairies et marchands de journaux': 'Librairies et marchands (4592)',
    'Industries de l\'enregistrement sonore': 'Enregistrement sonore (5122)',
    'Stations de radiodiffusion et de télédiffusion': 'Stations radio/télé (5161)',
    'Établissements du patrimoine': 'Patrimoine (712, 7121)',
    'Industries du film et de l\'enregistrement sonore': 'Film et enregistrement sonore (512)',
    'Industries du film et de vidéo': 'Film et vidéo (5121)',
    'Compagnies d\'arts d\'interprétation': 'Compagnies d\'arts d\'interprétation (7111)',
    'Éditeurs de journaux, de périodiques, de livres et de répertoires':'Éditeurs (5131)',
    'Services de distribution de contenu médiatique diffusé en continu et autres réseaux et fournisseurs de contenu médiatique':'Distribution contenu en continu (5162)',
  };
  const rows = D.emplois_2025
    .filter(r => r.industrie && r.industrie !== 'Ensemble des industries' && r.industrie !== 'Industries de services')
    .filter(r => r.serie_terminee !== 'True')
    .map(r => ({
      label: labelMap[r.industrie] || (r.industrie + (r.scian ? ' ('+r.scian+')' : '')),
      var_pct: parseFloat(r.variation_pct),
    }))
    .filter(r => !isNaN(r.var_pct))
    .sort((a,b) => a.var_pct - b.var_pct);
  const colors = rows.map(r => r.var_pct < -5 ? C.bo : r.var_pct < 0 ? C.bo600 : r.var_pct > 10 ? C.green : C.bb);
  new Chart(document.getElementById('chart_emplois'), {
    type: 'bar', data: { labels: rows.map(r => r.label),
      datasets: [{ data: rows.map(r => r.var_pct), backgroundColor: colors, borderRadius: 6, borderSkipped: false }]},
    options: { indexAxis: 'y', responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false },
        tooltip: { callbacks: { label: c => (c.parsed.x >= 0 ? '+' : '') + c.parsed.x.toFixed(1) + ' %' }}},
      scales: { x: { grid: { color: '#f0f4f8' }, ticks: { callback: v => v + ' %' }},
        y: { grid: { display: false }}}}
  });
})();

// === SCROLL SPY ===
(function(){
  const navLinks = document.querySelectorAll('.nav a[data-section]');
  const sections = Array.from(navLinks).map(a => document.getElementById(a.dataset.section));
  const setActive = id => {
    navLinks.forEach(a => a.classList.toggle('active', a.dataset.section === id));
  };
  const obs = new IntersectionObserver(entries => {
    const visible = entries.filter(e => e.isIntersecting).sort((a,b) => b.intersectionRatio - a.intersectionRatio);
    if (visible[0]) setActive(visible[0].target.id);
  }, { rootMargin: '-100px 0px -50% 0px', threshold: [0, 0.25, 0.5, 0.75, 1] });
  sections.forEach(s => s && obs.observe(s));
})();

// Smooth-scroll
document.querySelectorAll('.nav a[href^="#"]').forEach(a => {
  a.addEventListener('click', e => {
    e.preventDefault();
    document.getElementById(a.getAttribute('href').slice(1)).scrollIntoView({behavior:'smooth',block:'start'});
  });
});
</script>
</body>
</html>
